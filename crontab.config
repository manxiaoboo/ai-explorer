# Atooli Trending Algorithm - Cron Configuration
# 
# Setup instructions:
# 1. Copy this to your server's crontab: crontab -e
# 2. Or use Vercel Cron Jobs (vercel.json)
# 3. Set CRON_SECRET environment variable for API authentication
#

# Option 1: Direct script execution (if running on VPS/server)
# Daily at 2:00 AM - Full trending update
0 2 * * * cd /path/to/ai-explorer && npx tsx scripts/daily-trending-update.ts >> /var/log/atooli-trending.log 2>&1

# Hourly - Update GitHub stats only (less intensive)
0 * * * * cd /path/to/ai-explorer && npx tsx scripts/update-github-stats.ts >> /var/log/atooli-github.log 2>&1

# Twice daily - Update HuggingFace stats
0 6,18 * * * cd /path/to/ai-explorer && npx tsx scripts/update-huggingface-stats.ts >> /var/log/atooli-hf.log 2>&1

# Weekly on Sundays - Reset counters and full recalculation
0 3 * * 0 cd /path/to/ai-explorer && npx tsx scripts/calculate-trending-scores.ts >> /var/log/atooli-calc.log 2>&1

# ---

# Option 2: Vercel Cron Jobs (recommended for Vercel deployment)
# Add to vercel.json:
#
# {
#   "crons": [
#     {
#       "path": "/api/cron/calculate-trending?secret=YOUR_CRON_SECRET",
#       "schedule": "0 2 * * *"
#     }
#   ]
# }
#
# Then visit: https://vercel.com/dashboard -> Your Project -> Settings -> Cron Jobs
